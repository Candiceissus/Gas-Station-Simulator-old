local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/bloodball/-back-ups-for-libs/main/0x"))()

local UIS = game:GetService("UserInputService")
local lp = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local remote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("MaxFuelAction")
local fuelType = ReplicatedStorage:WaitForChild("Values"):WaitForChild("Items"):WaitForChild("FuelTypes"):WaitForChild("gasoline")

local autoSellEnabled = false
local wsEnabled = false
local jpEnabled = false
local wsValue = 16
local jpValue = 50
local uiToggled = true
local scriptRunning = true

local w1 = library:Window("Gas Station Simulator")

w1:Toggle("Auto Sell Gas", "asell", false, function(v)
    autoSellEnabled = v
    if autoSellEnabled then
        task.spawn(function()
            while autoSellEnabled and scriptRunning do
                remote:FireServer(fuelType, "sell")
                task.wait(0.1)
            end
        end)
    end
end)

w1:Toggle("Enable Custom Speed", "ws_toggle", false, function(v)
    wsEnabled = v
    if wsEnabled then
        task.spawn(function()
            while wsEnabled and scriptRunning do
                if lp.Character and lp.Character:FindFirstChild("Humanoid") then
                    lp.Character.Humanoid.WalkSpeed = wsValue
                end
                task.wait() 
            end
        end)
    end
end)

w1:Slider("Speed Value", "ws_amt", 16, 300, function(v) 
    wsValue = v 
end)

w1:Toggle("Enable Custom Jump", "jp_toggle", false, function(v)
    jpEnabled = v
    if jpEnabled then
        task.spawn(function()
            while jpEnabled and scriptRunning do
                if lp.Character and lp.Character:FindFirstChild("Humanoid") then
                    lp.Character.Humanoid.JumpPower = jpValue
                    lp.Character.Humanoid.UseJumpPower = true
                end
                task.wait()
            end
        end)
    end
end)

w1:Slider("Jump Value", "jp_amt", 50, 300, function(v) 
    jpValue = v 
end, 50)

w1:Button("Destroy GUI", function()
    scriptRunning = false
    autoSellEnabled = false
    wsEnabled = false
    jpEnabled = false
    
    for i, v in pairs(game.CoreGui:GetChildren()) do
        if v:FindFirstChild("Top") then 
            v:Destroy() 
        end
    end
end)

local MyGui = nil
task.spawn(function()
    while not MyGui and scriptRunning do
        for _, v in pairs(game.CoreGui:GetChildren()) do
            if v:FindFirstChild("Top") and v:IsA("ScreenGui") then
                MyGui = v
                break
            end
        end
        task.wait(0.5)
    end

    while MyGui and scriptRunning do
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) or UIS:IsKeyDown(Enum.KeyCode.RightShift) then
            MyGui.Enabled = uiToggled
        end
        task.wait()
    end
end)

UIS.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.Insert and scriptRunning then
        uiToggled = not uiToggled
        if MyGui then
            MyGui.Enabled = uiToggled
        end
    end
end)
